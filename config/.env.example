# =============================================================================
# OPENCLAW-system - Environment Configuration Template
# =============================================================================
# Copia este archivo a ~/.openclaw/config/.env y completa los valores
# Genera tokens seguros con: openssl rand -hex 24
# =============================================================================
# Arquitectura: Concilio Tri-Agente (Director + Ejecutor + Archivador)
# =============================================================================

# =============================================================================
# SISTEMA
# =============================================================================
NODE_ENV=production
LOG_LEVEL=info
LOG_FORMAT=json

# =============================================================================
# SEGURIDAD
# =============================================================================
# Genera con: openssl rand -hex 24
OPENCLAW_ENCRYPTION_KEY=GENERATE_WITH_OPENSSL
GATEWAY_TOKEN=GENERATE_WITH_OPENSSL

# =============================================================================
# CONCILIO TRI-AGENTE (3 Procesos Node.js)
# =============================================================================
# Director (Coordinador, Planeación)
DIRECTOR_PORT=8081
DIRECTOR_MODEL=claude-opus-4-6

# Ejecutor (Producción, Herramientas)
EJECUTOR_PORT=8082
EJECUTOR_MODEL=claude-sonnet-4-6

# Archivador (Validación, Memoria)
ARCHIVADOR_PORT=8083
ARCHIVADOR_MODEL=claude-haiku-4-5

# =============================================================================
# GATEWAY (Fastify + WebSocket)
# =============================================================================
GATEWAY_URL=ws://127.0.0.1:18789
GATEWAY_BIND=127.0.0.1
GATEWAY_PORT=18789
# IMPORTANTE: El Gateway NO debe exponerse a internet
# Solo accesible desde localhost y Tailscale (100.x.x.x)

# =============================================================================
# REDIS (Message Broker - Obligatorio)
# =============================================================================
REDIS_URL=redis://127.0.0.1:6379
REDIS_PASSWORD=

# =============================================================================
# LLM PROVIDERS - OBLIGATORIO AL MENOS UNO
# =============================================================================
# Sin al menos una API key configurada, el sistema no funcionará

# --- Z.AI / ZhipuAI (Recomendado para uso principal) ---
ZHIPUAI_API_KEY=tu-zhipu-api-key-aqui
# Modelos disponibles: glm-5, glm-4.7, glm-4.6, glm-4.6v, glm-4.5-air, glm-4.5-flash

# --- Anthropic (Máxima calidad) ---
# ANTHROPIC_API_KEY=sk-ant-tu-api-key-aqui

# --- OpenAI (Alternativa) ---
# OPENAI_API_KEY=sk-tu-api-key-aqui
# OPENAI_ORG_ID=org-xxx

# --- Minimax (Alternativa económica) ---
# MINIMAX_API_KEY=tu-minimax-key-aqui
# MINIMAX_GROUP_ID=tu-group-id-aqui

# --- Google AI ---
# GOOGLE_API_KEY=tu-google-api-key

# --- Azure OpenAI ---
# AZURE_OPENAI_API_KEY=tu-azure-key
# AZURE_OPENAI_ENDPOINT=https://tu-recurso.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4

# =============================================================================
# OLLAMA (LLM Local - Opcional)
# =============================================================================
OLLAMA_HOST=127.0.0.1:11434
OLLAMA_DEFAULT_MODEL=openclaw-llama32
# OLLAMA_REMOTE_HOST=192.168.1.100:11434

# =============================================================================
# LM STUDIO (LLM Local - Opcional)
# =============================================================================
# LMSTUDIO_HOST=127.0.0.1:1234

# =============================================================================
# BASE DE DATOS
# =============================================================================
DATABASE_URL=sqlite://$HOME/.openclaw/data/openclaw.db
VECTOR_DB_PATH=$HOME/.openclaw/data/vectors

# =============================================================================
# MEMORIA (LanceDB)
# =============================================================================
MEMORY_ENABLED=true
MEMORY_MAX_ENTRIES=10000
EMBEDDING_MODEL=nomic-embed-text
LANCEDB_PATH=$HOME/.openclaw/data/lancedb

# =============================================================================
# CANALES - Telegram (Recomendado)
# =============================================================================
TELEGRAM_BOT_TOKEN=tu-bot-token-aqui
TELEGRAM_ALLOWED_USERS=123456789,987654321

# =============================================================================
# CANALES - Discord (Opcional)
# =============================================================================
# DISCORD_BOT_TOKEN=tu-discord-bot-token
# DISCORD_CHANNEL_ID=123456789

# =============================================================================
# CANALES - Slack (Opcional)
# =============================================================================
# SLACK_BOT_TOKEN=xoxb-tu-token
# SLACK_APP_TOKEN=xapp-tu-token

# =============================================================================
# TAILSCALE (Acceso Remoto Seguro)
# =============================================================================
# Tailscale proporciona acceso seguro sin exponer puertos a internet
# El Gateway (18789) debe estar accesible solo via Tailscale
TAILSCALE_ENABLED=true
# TAILSCALE_AUTH_KEY=tskey-auth-xxx

# =============================================================================
# MONITOREO (Opcional)
# =============================================================================
GRAFANA_PASSWORD=admin
PROMETHEUS_ENABLED=false

# =============================================================================
# PATHS DE INSTALACIÓN
# =============================================================================
# Ajusta estas rutas según tu sistema
OPENCLAW_ROOT=/opt/openclaw
# Para Mac: /Volumes/NVMe-4TB/openclaw
# Para Linux: /opt/openclaw

# =============================================================================
# BACKUPS
# =============================================================================
BACKUP_DIR=/var/backups/openclaw
BACKUP_RETENTION_DAYS=30
