# EditorConfig - https://editorconfig.org

root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# Markdown files
[*.md]
indent_size = 2
max_line_length = 100

# YAML files
[*.{yaml,yml}]
indent_size = 2

# JSON files
[*.json]
indent_size = 2

# Python files
[*.py]
indent_size = 4

# Shell scripts
[*.sh]
indent_size = 2

# Makefile
[Makefile]
indent_style = tab

# Git attributes
[.gitattributes]
end_of_line = lf

# Ignore patterns for certain file types
[*.min.js]
trim_trailing_whitespace = false

[*.min.css]
trim_trailing_whitespace = false
